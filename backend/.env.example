# ============================================================================
# BACKEND CONFIGURATION (.env - backend folder)
# ============================================================================
# For production deployment on Render/Railway

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=production

# Model Configuration
# Options: demo_model.pth, best_model.pth
MODEL_CHECKPOINT=demo_model.pth

# Device (cpu, cuda, mps)
DEVICE=cpu

# Logging
LOG_LEVEL=INFO

# CORS (set to specific domain in production)
CORS_ORIGINS=*
